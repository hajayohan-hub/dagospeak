    { "speaker": "B", "text": "Qui est-ce ?", "translation": "Iza izany?", "highlight": "Qui" },
    { "speaker": "A", "text": "C'est mon père. Et elle, c'est ma mère.", "translation": "Ny raiko izany. Ary izy kosa, ny reniko.", "highlight": "père" },
    { "speaker": "B", "text": "Et ton frère ?", "translation": "Ary ny anadahinao?", "highlight": "frère" },
    { "speaker": "A", "text": "Il est grand. Ma sœur est petite.", "translation": "Lehibe izy. Kely ny anabaviko.", "highlight": "grand" }
